# Discord gateway
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=<discord-user-id>
DISCORD_ALLOWED_CHANNELS=<discord-channel-id>
DISCORD_REQUIRE_MENTION=true
DISCORD_HOME_CHANNEL=<discord-channel-id>
DISCORD_HOME_CHANNEL_THREAD_ID=

# GitHub PR workflow
GH_HOST=github.com
GH_USER=<github-bot-user>
GITHUB_USER=<github-bot-user>
GITHUB_FORK_OWNER=<github-bot-user>
GH_PROMPT_DISABLED=1
GIT_TERMINAL_PROMPT=0
GIT_AUTHOR_NAME=<github-bot-user>
GIT_AUTHOR_EMAIL=<github-bot-user>@users.noreply.github.com
GIT_COMMITTER_NAME=<github-bot-user>
GIT_COMMITTER_EMAIL=<github-bot-user>@users.noreply.github.com

GH_TOKEN=
